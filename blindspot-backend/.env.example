# Blindspot Environment Variables (v2)
# Copy this file to .env and fill in real values. Never commit .env.

# --- Cencori AI Gateway ---
# Single key in code. Provider keys (Anthropic, OpenAI, Google) live in the
# Cencori dashboard, NOT here. Cencori routes Claude -> GPT-4o -> Gemini.
CENCORI_API_KEY=cen-...
CENCORI_BASE_URL=https://api.cencori.com/v1

# These go into your Cencori dashboard, not in code:
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=...

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# --- External data APIs ---
NUMBEO_API_KEY=your_numbeo_api_key_here
OPENEXCHANGERATES_KEY=your_open_exchange_rates_app_id_here
