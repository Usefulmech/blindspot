# Blindspot Environment Variables
# Do not commit the actual .env file to version control

# Supabase
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_anon_key_here

# Anthropic (Claude 3.5 Sonnet)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# External APIs
NUMBEO_API_KEY=your_numbeo_api_key_here
OPENEXCHANGERATES_APP_ID=your_open_exchange_rates_app_id_here
TELEPORT_API_KEY=your_teleport_api_key_here # Or NO_AUTH if not required
UNESCO_UIS_API_KEY=your_unesco_api_key_here

